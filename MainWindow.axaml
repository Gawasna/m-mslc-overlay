<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:transcript="using:m_mslc_overlay.views.content.transcript"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="m_mslc_overlay.MainWindow"
        Title="{DynamicResource Title_ControlCenter}"
        Background="{StaticResource BgWindowBrush}"
        MinWidth="960" MinHeight="300"
        Width="1200" Height="768"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Border.SidebarItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Border.SidebarItem materialIcons|MaterialIcon">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.SidebarItem:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
        </Style>
        <Style Selector="Border.SidebarItem.Active">
            <Setter Property="Background" Value="{StaticResource TranscriptActiveRowBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.SidebarItem.Active TextBlock">
            <Setter Property="TextDecorations" Value="Underline"/>
        </Style>

        <!-- Responsive Sidebar Mini Mode styles -->
        <Style Selector="Border.Mini TextBlock">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Border.Mini Border.SidebarItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style Selector="Border.Mini Border.SidebarItem materialIcons|MaterialIcon">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Grid.ColumnSpan" Value="2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Mini mode Recent Block responsive adjustments -->
        <Style Selector="Border.Mini Border.RecentBlock">
            <Setter Property="Padding" Value="0,12"/>
        </Style>
        <Style Selector="Border.Mini Border.PathBorder">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Border.Mini StackPanel.PathActions">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Spacing" Value="6"/>
        </Style>
        <Style Selector="Border.Mini Button.ToggleSidebarBtn">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Border.Mini Button.CopyPathBtn">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, Auto, *, Auto">
        
        <!-- 1. Primary Toolbar (Menu Bar) -->
        <Border Grid.Row="0" 
                Height="{StaticResource PrimaryToolbarHeight}" 
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="{StaticResource BorderThicknessBottomOnly}"
                Padding="8,0">
            <Menu VerticalAlignment="Center">
                <MenuItem Header="{DynamicResource Menu_File}">
                    <MenuItem Header="{DynamicResource Menu_InjectTargetDll}">
                        <MenuItem Header="{DynamicResource Menu_ByActivePid}" />
                        <MenuItem Header="{DynamicResource Menu_ByProcessName}" />
                        <MenuItem Header="{DynamicResource Menu_OpenInjectionLog}" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="{DynamicResource Menu_Exit}" InputGesture="Alt+F4" />
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Edit}">
                    <MenuItem Header="{DynamicResource Menu_CopySelectedLog}" InputGesture="Ctrl+C" />
                    <MenuItem Header="{DynamicResource Menu_ClearHistoryLog}" InputGesture="Ctrl+L" />
                    <Separator />
                    <MenuItem Header="{DynamicResource Menu_Preferences}" InputGesture="Ctrl+," Click="PreferencesMenuItem_Click" />
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_View}">
                    <MenuItem Header="{DynamicResource Menu_ToggleFloatingOverlay}" InputGesture="F5" />
                    <MenuItem Header="{DynamicResource Menu_ToggleDebugWidget}" InputGesture="F6" />
                    <MenuItem Header="Toggle Side Panel (Mockup)" InputGesture="F7" Click="ToggleSidePanel_Click" />
                    <Separator />
                    <MenuItem Header="{DynamicResource Menu_KeepOnTop}" />
                    <Separator />
                    <MenuItem Header="{DynamicResource Menu_Language}">
                        <MenuItem Header="Tiếng Việt (vi-VN)" Click="ChangeLanguage_Vi_Click" />
                        <MenuItem Header="English (en-US)" Click="ChangeLanguage_En_Click" />
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Tools}">
                    <MenuItem Header="{DynamicResource Menu_NamedPipeMonitor}" />
                    <MenuItem Header="{DynamicResource Menu_ActiveExtractorCheckout}" Click="ActiveExtractorCheckout_Click" />
                    <MenuItem Header="{DynamicResource Menu_SystemDiagnostics}" />
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Help}">
                    <MenuItem Header="{DynamicResource Menu_ViewDocumentation}" InputGesture="F1" />
                    <MenuItem Header="Kiểm tra môi trường hệ thống (UAC)..." Click="CheckEnvironmentMenuItem_Click" />
                    <MenuItem Header="{DynamicResource Menu_CheckForUpdates}" />
                    <MenuItem Header="{DynamicResource Menu_AboutControlCenter}" />
                </MenuItem>
            </Menu>
        </Border>

        <!-- 2. Secondary Toolbar (Quick Actions) -->
        <Border Grid.Row="1" 
                Height="{StaticResource SecondaryToolbarHeight}" 
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="{StaticResource BorderThicknessBottomOnly}"
                Padding="8,0">
            <DockPanel LastChildFill="False">
                <!-- Left: Quick Action Buttons (Icon only, no corner radius) -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Inject DLL Button -->
                    <Button x:Name="InjectBtn" 
                            Click="InjectBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}" 
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0" 
                            Classes="PrimaryBtn"
                            ToolTip.Tip="{DynamicResource Tooltip_InjectDll}">
                        <materialIcons:MaterialIcon Kind="Flash" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource BgCardBrush}" />
                    </Button>
                    <!-- Open Overlay Button -->
                    <Button Click="OpenOverlayBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}" 
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0" 
                            Classes="SecondaryBtn"
                            ToolTip.Tip="{DynamicResource Tooltip_OpenOverlay}">
                        <materialIcons:MaterialIcon Kind="Play" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                    <!-- Open Debug / Settings Button -->
                    <Button Click="OpenDebugWidgetBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}" 
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0" 
                            Classes="SecondaryBtn"
                            ToolTip.Tip="{DynamicResource Tooltip_OpenDebugSettings}">
                        <materialIcons:MaterialIcon Kind="Cog" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                    <!-- PaperSheet Demo Button -->
                    <Button Click="OpenPaperSheetDemoBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}" 
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0" 
                            Classes="SecondaryBtn"
                            ToolTip.Tip="Open PaperSheet Demo">
                        <materialIcons:MaterialIcon Kind="FileDocumentEdit" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                    <!-- TipTap Demo Button -->
                    <Button Click="OpenTipTapDemoBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}" 
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0" 
                            Classes="SecondaryBtn"
                            ToolTip.Tip="TipTap Editor Demo">
                        <materialIcons:MaterialIcon Kind="LanguageHtml5" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                    <!-- Quill Demo Button -->
                    <Button Click="OpenQuillDemoBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}" 
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0" 
                            Classes="SecondaryBtn"
                            ToolTip.Tip="Quill Editor Demo">
                        <materialIcons:MaterialIcon Kind="Feather" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                    <!-- Monaco Demo Button -->
                    <Button Click="OpenMonacoDemoBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}" 
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0" 
                            Classes="SecondaryBtn"
                            ToolTip.Tip="Monaco Editor Demo">
                        <materialIcons:MaterialIcon Kind="CodeBraces" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                    <!-- Theme Toggle Button (cycles: System → Light → Dark) -->
                    <Button x:Name="ThemeToggleBtn" Click="ThemeToggleBtn_Click"
                            Width="{StaticResource QuickActionButtonSize}" Height="{StaticResource QuickActionButtonSize}"
                            CornerRadius="{StaticResource CornerRadiusZero}" Padding="0"
                            Classes="SecondaryBtn"
                            ToolTip.Tip="Toggle Theme (System / Light / Dark)">
                        <materialIcons:MaterialIcon x:Name="ThemeIcon" Kind="WeatherSunny" Width="{StaticResource QuickActionIconSize}" Height="{StaticResource QuickActionIconSize}" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 3. Blank Section (Content Area) -->
        <Grid Grid.Row="2" x:Name="MainContentGrid" ColumnDefinitions="240, Auto, *">
            <!-- Sidebar_Panel -->
            <Border Grid.Column="0" 
                    x:Name="SidebarBorder"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource BgWindowBrush}" 
                    BorderBrush="{StaticResource BorderLightBrush}" 
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="7*, 3*">
                    <!-- Sidebar_Primary_Slot -->
                    <Grid Grid.Row="0" RowDefinitions="Auto, *">
                        <!-- Recent Block (Current Session) -->
                        <Border Grid.Row="0" 
                                Classes="RecentBlock"
                                Background="Transparent" 
                                BorderBrush="{StaticResource BorderLightBrush}" 
                                BorderThickness="0,0,0,1" 
                                Padding="16,12">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="Session:" 
                                               FontWeight="SemiBold" 
                                               FontSize="12" 
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="Interview with Tech Lead" 
                                               FontWeight="Bold" 
                                               FontSize="13" 
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                
                                <TextBlock Text="Last Modified: 2026-07-19 14:30" 
                                           FontSize="11" 
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                           
                                <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                                    <!-- Workspace path container -->
                                    <Border Grid.Column="0" 
                                            Classes="PathBorder"
                                            Background="{StaticResource BgCardBrush}" 
                                            BorderBrush="{StaticResource BorderBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="0" 
                                            Padding="8,4" 
                                            Margin="0,0,8,0">
                                        <TextBlock Text="C:\Workspaces\TechLead_2026..." 
                                                   FontSize="11" 
                                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    
                                    <!-- Actions Panel -->
                                    <StackPanel Grid.Column="1" Classes="PathActions" Orientation="Horizontal" Spacing="4">
                                        <!-- Toggle Sidebar Button -->
                                        <Button x:Name="ToggleSidebarBtn"
                                                Click="ToggleSidebarBtn_Click"
                                                Classes="SecondaryBtn ToggleSidebarBtn"
                                                Padding="6,4"
                                                Height="24"
                                                CornerRadius="0"
                                                ToolTip.Tip="Expand/Collapse Sidebar">
                                            <materialIcons:MaterialIcon Kind="DockLeft" Width="12" Height="12" Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Button>
                                        
                                        <!-- Copy button -->
                                        <Button Classes="SecondaryBtn CopyPathBtn"
                                                Padding="6,4"
                                                Height="24"
                                                CornerRadius="0"
                                                ToolTip.Tip="Copy Workspace Path">
                                            <materialIcons:MaterialIcon Kind="ContentCopy" Width="12" Height="12" Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        
                        <!-- Session Files list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Border Background="Transparent"
                                    BorderBrush="{StaticResource BorderLightBrush}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="0"
                                    Margin="0"
                                    Padding="4">
                                <StackPanel Spacing="2">
                                    <!-- File 1: transcript.srt (Active) -->
                                    <Border Classes="SidebarItem Active">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <!-- File icon -->
                                            <materialIcons:MaterialIcon Grid.Column="0" 
                                                                        Kind="FileDocumentOutline" 
                                                                        Width="14" 
                                                                        Height="14" 
                                                                        Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <!-- File name -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="transcript.srt" 
                                                       FontSize="12" 
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- File 2: audio_source.wav (Inactive) -->
                                    <Border Classes="SidebarItem">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <!-- File icon -->
                                            <materialIcons:MaterialIcon Grid.Column="0" 
                                                                        Kind="MusicNote" 
                                                                        Width="14" 
                                                                        Height="14" 
                                                                        Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <!-- File name -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="audio_source.wav" 
                                                       FontSize="12" 
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- File 3: notes.txt (Inactive) -->
                                    <Border Classes="SidebarItem">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <!-- File icon -->
                                            <materialIcons:MaterialIcon Grid.Column="0" 
                                                                        Kind="NotebookOutline" 
                                                                        Width="14" 
                                                                        Height="14" 
                                                                        Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <!-- File name -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="notes.txt" 
                                                       FontSize="12" 
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </Grid>

                    <!-- Sidebar_Utility_Slot -->
                    <Grid Grid.Row="1" RowDefinitions="Auto, *">
                        <!-- Status Block -->
                        <Border Grid.Row="0" Height="24" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,1,0,1" Padding="12,0">
                            <TextBlock Text="Status" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>
                        <!-- Status List -->
                        <Border Grid.Row="1" Background="Transparent" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="12">
                            <StackPanel Spacing="10">
                                <!-- Python runtime -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="StatusDotPython" Width="8" Height="8" Fill="{StaticResource StatusInactiveBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusTextPython" Text="Python runtime" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Live caption -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="StatusDotCaption" Width="8" Height="8" Fill="{StaticResource StatusInactiveBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusTextCaption" Text="Live caption" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- CUDA status -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="StatusDotCuda" Width="8" Height="8" Fill="{StaticResource StatusInactiveBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusTextCuda" Text="CUDA status" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Extractor module -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="StatusDotExtractor" Width="8" Height="8" Fill="{StaticResource StatusInactiveBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusTextExtractor" Text="Extractor module" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Local Network -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="StatusDotNetwork" Width="8" Height="8" Fill="{StaticResource StatusInactiveBrush}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusTextNetwork" Text="Local Network" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Sidebar Drag Splitter -->
            <GridSplitter Grid.Column="1" 
                          Width="5" 
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Main_Viewport: Transcript Viewport (Word-style bilingual transcript) -->
            <transcript:TranscriptViewport x:Name="TranscriptViewport"
                                           Grid.Column="2" />
        </Grid>

        <!-- 4. Downbar (Status Bar) -->
        <Border Grid.Row="3" 
                Height="24" 
                Background="{StaticResource BgWindowBrush}" 
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid ColumnDefinitions="*, Auto, *">
                <!-- Trái: Trạng thái vận hành -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <TextBlock x:Name="StatusBarMainText" 
                               Text="{DynamicResource Status_Ready}" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11"/>
                </StackPanel>

                <!-- Giữa: Thông tin mô hình AI -->
                <TextBlock Grid.Column="1" 
                           x:Name="StatusBarInfoText"
                           Text="AI Model: Gemini 1.5 Pro | Topic: Game/Phim" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="11" 
                           VerticalAlignment="Center"/>

                <!-- Phải: Các chỉ báo kỹ thuật -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Spacing="16">
                    <!-- Resource Usage -->
                    <TextBlock x:Name="ResourceUsageText" 
                               Text="SYS: 0% CPU 0MB | APP: 0% CPU 0MB" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11" 
                               VerticalAlignment="Center"/>
                               
                    <!-- Target PID -->
                    <TextBlock x:Name="TargetPidText" 
                               Text="{DynamicResource Status_PidNotRunning}" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="11"/>
                    
                    <!-- Hook Status -->
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse x:Name="HookStatusDot" 
                                 Width="8" Height="8" 
                                 Fill="{StaticResource StatusInactiveBrush}" 
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="HookStatusText" 
                                   Text="{DynamicResource Status_Disconnected}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="11" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>

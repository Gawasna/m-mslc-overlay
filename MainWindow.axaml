<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="m_mslc_overlay.MainWindow"
        Title="MainWindow">
    <StackPanel>
        <Ellipse x:Name="HookStatusDot" Width="10" Height="10"/>
        <TextBlock x:Name="HookStatusText"/>
        <TextBlock x:Name="TargetPidText"/>
        <Button x:Name="InjectBtn" Click="InjectBtn_Click" Content="Inject"/>
        <TextBox x:Name="TopicInput"/>
        <ToggleSwitch x:Name="TranslateToggle"/>
        <Button Content="Open Overlay" Click="OpenOverlayBtn_Click"/>
        <Button Content="Open Debug" Click="OpenDebugWidgetBtn_Click"/>
        <ScrollViewer x:Name="LogScrollViewer" Height="200">
            <TextBox x:Name="RawTextLog"/>
        </ScrollViewer>
        <TextBlock x:Name="LiveRawText"/>
    </StackPanel>
</Window>

<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Base Color Brushes (Light Theme) -->
    <SolidColorBrush x:Key="BgWindowBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="BgCardBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#CBCCC9" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#E5E5E5" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111111" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666" />
    
    <!-- Primary Accent (Orange) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF8400" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#E07300" />
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#C26300" />
    
    <!-- Secondary Accent (Gray) -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#E7E8E5" />
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#D7D8D5" />
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#C7C8C5" />
    
    <!-- Menu/Toolbar Hover Background -->
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#F2F3F0" />
    
    <!-- Status Brushes -->
    <SolidColorBrush x:Key="StatusInactiveBrush" Color="#CBCCC9" />
    <SolidColorBrush x:Key="StatusActiveBrush" Color="#00FF00" /> <!-- Green placeholder for active hook -->

    <!-- Theme Resource Overrides to enforce orange styling for Fluent controls -->
    <SolidColorBrush x:Key="TextBoxBorderBrushFocused" Color="#FF8400" />
    <SolidColorBrush x:Key="TextBoxBorderBrushPointerOver" Color="#E07300" />
    
    <SolidColorBrush x:Key="CheckBoxBorderBrushChecked" Color="#FF8400" />
    <SolidColorBrush x:Key="CheckBoxBackgroundChecked" Color="#FF8400" />
    <SolidColorBrush x:Key="CheckBoxBackgroundCheckedPointerOver" Color="#E07300" />
    <SolidColorBrush x:Key="CheckBoxBackgroundCheckedPressed" Color="#C26300" />
    
    <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#FF8400" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#E07300" />
    <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#C26300" />

    <!-- ─── Transcript Viewport Semantic Tokens ────────────────────────────────
         Derived from the app's Primary orange so the transcript stays on-schema.
         Use these instead of raw blue hex values in transcript AXAML files.      -->

    <!-- Active segment left border (orange accent, muted) -->
    <SolidColorBrush x:Key="TranscriptActiveBorderBrush" Color="#FF8400" />
    <!-- Active segment row background (very light orange wash) -->
    <SolidColorBrush x:Key="TranscriptActiveRowBrush" Color="#FFF4E6" />
    <!-- Pending translation row background (amber warning, matches status bar) -->
    <SolidColorBrush x:Key="TranscriptPendingBrush" Color="#FFFBEB" />
    <!-- Translation text color (dark orange, stays readable on white) -->
    <SolidColorBrush x:Key="TranscriptTranslationTextBrush" Color="#B45309" />
    <!-- Translation block background (light orange tint) -->
    <SolidColorBrush x:Key="TranscriptTranslationBgBrush" Color="#FFF7ED" />
    <!-- Live cursor / recording accent (Primary orange) -->
    <SolidColorBrush x:Key="TranscriptLiveCursorBrush" Color="#FF8400" />
    <!-- Live cursor row background -->
    <SolidColorBrush x:Key="TranscriptLiveCursorRowBrush" Color="#FFF4E6" />
    <!-- Word Status Bar background — dark charcoal keeps neutrality, avoids blue -->
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="#1C1C1E" />
    <!-- Word Status Bar text -->
    <SolidColorBrush x:Key="StatusBarFgBrush" Color="#E5E5E5" />

</ResourceDictionary>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:m_mslc_overlay.viewmodels.transcript"
             x:Class="m_mslc_overlay.views.content.transcript.DocumentNavigationPane"
             x:DataType="vm:NavPaneViewModel"
             Width="220" MinWidth="180" MaxWidth="400">

    <Grid RowDefinitions="Auto, *" IsVisible="{Binding IsVisible}">

        <!-- ─── Pane Header ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgWindowBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,1"
                Height="32"
                Padding="8,0">
            <Grid ColumnDefinitions="Auto, *, Auto">

                <!-- State switcher: icon-style tabs -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">

                    <!-- Speaker Annotation -->
                    <Button x:Name="BtnSpeaker"
                            Width="22" Height="22" Padding="0" CornerRadius="3"
                            ToolTip.Tip="Speaker Annotation"
                            Classes="NavTabBtn">
                        <TextBlock Text="SP" FontSize="8" FontWeight="Bold" />
                    </Button>

                    <!-- Find & Replace -->
                    <Button x:Name="BtnFindReplace"
                            Width="22" Height="22" Padding="0" CornerRadius="3"
                            ToolTip.Tip="Find &amp; Replace"
                            Classes="NavTabBtn">
                        <TextBlock Text="⌕" FontSize="11" />
                    </Button>

                    <!-- AI Summary -->
                    <Button x:Name="BtnSummary"
                            Width="22" Height="22" Padding="0" CornerRadius="3"
                            ToolTip.Tip="AI Summary"
                            Classes="NavTabBtn">
                        <TextBlock Text="AI" FontSize="8" FontWeight="Bold" />
                    </Button>

                    <!-- AI Auto-Correct -->
                    <Button x:Name="BtnAutoCorrect"
                            Width="22" Height="22" Padding="0" CornerRadius="3"
                            ToolTip.Tip="AI Auto-Correct"
                            Classes="NavTabBtn">
                        <TextBlock Text="✓" FontSize="10" />
                    </Button>

                    <!-- Glossary -->
                    <Button x:Name="BtnGlossary"
                            Width="22" Height="22" Padding="0" CornerRadius="3"
                            ToolTip.Tip="Glossary"
                            Classes="NavTabBtn">
                        <TextBlock Text="G" FontSize="10" FontWeight="Bold" />
                    </Button>

                </StackPanel>

                <!-- Compact toggle / close -->
                <Button Grid.Column="2"
                        x:Name="BtnClose"
                        Content="×" FontSize="12"
                        Width="20" Height="20"
                        Padding="0" CornerRadius="2"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TextSecondaryBrush}" />

            </Grid>
        </Border>

        <!-- ─── State Panels ────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">

            <Panel>

                <!-- ══ STATE 1: Speaker Annotation ════════════════════════════ -->
                <StackPanel IsVisible="{Binding ShowSpeakerAnnotation}"
                            Spacing="0">

                    <!-- Header -->
                    <Border Background="{StaticResource BgWindowBrush}" BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <TextBlock Text="Speaker Annotation"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </Border>

                    <!-- Speaker list -->
                    <ItemsControl ItemsSource="{Binding Speakers}"
                                  Padding="0">
                        <ItemsControl.DataTemplates>
                            <DataTemplate x:DataType="vm:SpeakerAnnotation">
                                <Border BorderBrush="{StaticResource BgWindowBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <!-- Speaker color dot -->
                                        <Ellipse Grid.Column="0"
                                                 Width="10" Height="10"
                                                 Fill="{StaticResource PrimaryBrush}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0" />
                                        <!-- Editable display name -->
                                        <StackPanel Grid.Column="1" Spacing="1">
                                            <TextBlock Text="{Binding SpeakerKey}"
                                                       FontSize="9" Foreground="#9CA3AF" />
                                            <TextBox Text="{Binding DisplayName}"
                                                     FontSize="11"
                                                     Padding="2,1"
                                                     Background="Transparent"
                                                     BorderThickness="0,0,0,1"
                                                     BorderBrush="{StaticResource BorderBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.DataTemplates>
                    </ItemsControl>

                    <!-- Hint when empty -->
                    <TextBlock Text="Speakers will appear here as segments arrive."
                               FontSize="10" Foreground="#9CA3AF"
                               TextWrapping="Wrap" Margin="10,12" />

                </StackPanel>

                <!-- ══ STATE 2: Find & Replace ════════════════════════════════ -->
                <StackPanel IsVisible="{Binding ShowFindReplace}" Spacing="0">

                    <!-- Header -->
                    <Border Background="{StaticResource BgWindowBrush}" BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <TextBlock Text="Find &amp; Replace"
                                   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Border>

                    <StackPanel Spacing="8" Margin="10">

                        <!-- Find field -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="Find" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="FindTextBox"
                                     Text="{Binding FindReplace.FindText}"
                                     FontSize="11" Height="28"
                                     Watermark="Search in transcript..." />
                        </StackPanel>

                        <!-- Replace field -->
                        <StackPanel Spacing="3">
                            <TextBlock Text="Replace with" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox x:Name="ReplaceTextBox"
                                     Text="{Binding FindReplace.ReplaceText}"
                                     FontSize="11" Height="28"
                                     Watermark="Replacement text..." />
                        </StackPanel>

                        <!-- Action buttons -->
                        <Grid ColumnDefinitions="*, 8, *">
                            <Button Grid.Column="0" x:Name="FindNextBtn"
                                    Content="Find Next"
                                    FontSize="10" Padding="0,5"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Classes="SecondaryBtn" CornerRadius="3" />
                            <Button Grid.Column="2" x:Name="ReplaceAllBtn"
                                    Content="Replace All"
                                    FontSize="10" Padding="0,5"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Classes="PrimaryBtn" CornerRadius="3" />
                        </Grid>

                        <!-- Result message -->
                        <TextBlock Text="{Binding FindReplace.ResultMessage}"
                                   FontSize="10" Foreground="{StaticResource PrimaryBrush}"
                                   IsVisible="{Binding FindReplace.MatchCount,
                                               Converter={x:Static ObjectConverters.IsNotNull}}" />

                    </StackPanel>
                </StackPanel>

                <!-- ══ STATE 3: AI Summary ════════════════════════════════════ -->
                <StackPanel IsVisible="{Binding ShowAiSummary}" Spacing="0">

                    <!-- Header -->
                    <Border Background="#FFF4E6" BorderBrush="#FFD9AA"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0" Text="AI Summary"
                                       FontSize="11" FontWeight="SemiBold" Foreground="#1E40AF" />
                            <TextBlock Grid.Column="1"
                                       Text="Gemini"
                                       FontSize="9" Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Spacing="8" Margin="10">

                        <!-- Generate button -->
                        <Button x:Name="GenerateSummaryBtn"
                                Content="Generate Summary"
                                FontSize="10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="0,6"
                                Classes="PrimaryBtn" CornerRadius="3"
                                IsEnabled="{Binding !AiPane.IsBusy}" />

                        <!-- Busy indicator -->
                        <ProgressBar IsVisible="{Binding AiPane.IsBusy}"
                                     IsIndeterminate="True"
                                     Height="3" />

                        <!-- Summary output -->
                        <Border CornerRadius="3"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="8,6"
                                MinHeight="120">
                            <TextBlock Text="{Binding AiPane.SummaryText}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       LineHeight="18" />
                        </Border>

                    </StackPanel>
                </StackPanel>

                <!-- ══ STATE 4: AI Auto-Correct ═══════════════════════════════ -->
                <StackPanel IsVisible="{Binding ShowAiAutoCorrect}" Spacing="0">

                    <!-- Header -->
                    <Border Background="#F0FDF4" BorderBrush="#BBF7D0"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <TextBlock Text="AI Auto-Correct"
                                   FontSize="11" FontWeight="SemiBold" Foreground="#14532D" />
                    </Border>

                    <StackPanel Spacing="10" Margin="10">

                        <!-- Options -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="Correction scope" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" />
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <CheckBox IsChecked="{Binding AiPane.FixSpelling}"
                                              Width="14" Height="14" />
                                    <TextBlock Text="Fix spelling &amp; grammar"
                                               FontSize="11" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <CheckBox IsChecked="{Binding AiPane.ImproveStyle}"
                                              Width="14" Height="14" />
                                    <TextBlock Text="Improve readability"
                                               FontSize="11" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Run button -->
                        <Button x:Name="RunCorrectBtn"
                                Content="Apply Corrections"
                                FontSize="10"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="0,6"
                                Classes="PrimaryBtn" CornerRadius="3"
                                IsEnabled="{Binding !AiPane.IsBusy}" />

                        <!-- Busy indicator -->
                        <ProgressBar IsVisible="{Binding AiPane.IsBusy}"
                                     IsIndeterminate="True"
                                     Height="3" />

                        <!-- Result text -->
                        <TextBlock Text="{Binding AiPane.CorrectResultMessage}"
                                   FontSize="10" Foreground="#16A34A"
                                   TextWrapping="Wrap" />

                    </StackPanel>
                </StackPanel>

                <!-- ══ STATE 5: Glossary ══════════════════════════════════════ -->
                <Grid IsVisible="{Binding ShowGlossary}" RowDefinitions="Auto, *, Auto">

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="#FFF7ED" BorderBrush="#FED7AA"
                            BorderThickness="0,0,0,1" Padding="10,6">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Glossary"
                                       FontSize="11" FontWeight="SemiBold" Foreground="#92400E" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding GlossaryEntries.Count, StringFormat='{}{0} terms'}"
                                       FontSize="9" Foreground="#D97706" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Term list -->
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding GlossaryEntries}">
                            <ItemsControl.DataTemplates>
                                <DataTemplate x:DataType="vm:GlossaryEntry">
                                    <Border BorderBrush="#FEF3C7"
                                            BorderThickness="0,0,0,1"
                                            Padding="10,8">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Term}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#92400E" />
                                            <TextBlock Text="{Binding Definition}"
                                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.DataTemplates>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Add entry row -->
                    <Border Grid.Row="2"
                            Background="#FFF7ED"
                            BorderBrush="#FED7AA" BorderThickness="0,1,0,0"
                            Padding="8">
                        <StackPanel Spacing="4">
                            <TextBox x:Name="GlossaryTermBox"
                                     Watermark="Term..." FontSize="10" Height="24" />
                            <TextBox x:Name="GlossaryDefBox"
                                     Watermark="Definition..." FontSize="10" Height="24" />
                            <Button x:Name="AddGlossaryEntryBtn"
                                    Content="Add Term"
                                    FontSize="10" Padding="0,4"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Classes="SecondaryBtn" CornerRadius="3" />
                        </StackPanel>
                    </Border>
                </Grid>

            </Panel>
        </Border>

    </Grid>
</UserControl>

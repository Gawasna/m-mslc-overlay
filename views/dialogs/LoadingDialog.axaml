<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="m_mslc_overlay.views.dialogs.LoadingDialog"
        Title="Đang xử lý..."
        Width="350" Height="150"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="BorderOnly"
        Background="#FFFFFF">
    <Grid RowDefinitions="*, Auto" Margin="20">
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
            <ProgressBar x:Name="Spinner" IsIndeterminate="True" Height="4" Width="200" Foreground="#0078D7"/>
            <TextBlock x:Name="MessageText" Text="Vui lòng chờ..." FontSize="14" FontWeight="Medium" Foreground="#333333" TextAlignment="Center" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="m_mslc_overlay.views.dialogs.PreferencesDialog"
        Title="{DynamicResource Title_Preferences}"
        Width="720" Height="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#F9F9F9">
    <Grid ColumnDefinitions="200, *">
        
        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#F3F3F3" BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
            <ListBox x:Name="TabSelector" Background="Transparent" BorderThickness="0" Margin="0,8" SelectionChanged="TabSelector_SelectionChanged">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Margin" Value="8,2"/>
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#E5E5E5"/>
                        <Setter Property="Foreground" Value="#111111"/>
                    </Style>
                </ListBox.Styles>
                <ListBoxItem Content="{DynamicResource Tab_General}" IsSelected="True" />
                <ListBoxItem Content="{DynamicResource Tab_Translation}" />
                <ListBoxItem Content="{DynamicResource Tab_Appearance}" />
                <ListBoxItem Content="{DynamicResource Tab_Network}" />
                <ListBoxItem Content="{DynamicResource Tab_Advanced}" />
                <ListBoxItem Content="{DynamicResource Tab_Hotkeys}" />
            </ListBox>
        </Border>
        
        <!-- Content Area -->
        <Border Grid.Column="1" Background="#FFFFFF" Padding="24">
            <Grid RowDefinitions="*, Auto">
                
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <Panel>
                    
                    <!-- General Tab -->
                    <StackPanel x:Name="TabGeneral" IsVisible="True" Spacing="24">
                        <TextBlock Text="{DynamicResource Tab_General}" FontSize="24" FontWeight="SemiBold" Foreground="#111111"/>
                        <StackPanel Spacing="16">
                            <CheckBox x:Name="StartupCheck" Content="{DynamicResource Pref_General_Startup}" IsChecked="False"/>
                            <CheckBox x:Name="TrayIconCheck" Content="{DynamicResource Pref_General_TrayIcon}" IsChecked="True"/>
                            <CheckBox x:Name="CheckUpdatesCheck" Content="{DynamicResource Pref_General_CheckUpdates}" IsChecked="True"/>
                            <StackPanel Spacing="8" Margin="0,8,0,0">
                                <TextBlock Text="{DynamicResource Pref_General_Language}" FontSize="12" Foreground="#666666"/>
                                <ComboBox x:Name="LanguageCombo" Width="240" SelectedIndex="0">
                                    <ComboBoxItem Content="Tiếng Việt (vi-VN)"/>
                                    <ComboBoxItem Content="English (en-US)"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Translation Tab -->
                    <StackPanel x:Name="TabTranslation" IsVisible="False" Spacing="24">
                        <TextBlock Text="{DynamicResource Tab_Translation}" FontSize="24" FontWeight="SemiBold" Foreground="#111111"/>
                        <TabControl Margin="0,-8,0,0">
                            <TabControl.Styles>
                                <Style Selector="TabItem">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="MinHeight" Value="36"/>
                                </Style>
                            </TabControl.Styles>
                            <!-- Engine Dịch -->
                            <TabItem Header="{DynamicResource Pref_Trans_Engine}">
                                <StackPanel Spacing="16" Margin="0,16,0,0">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Translation Engine" FontSize="12" Foreground="#666666"/>
                                        <ComboBox x:Name="TranslationEngineCombo" Width="240" SelectedIndex="0">
                                            <ComboBoxItem Content="DeepL API"/>
                                            <ComboBoxItem Content="Cloud AI (Ollama/Gemini)"/>
                                            <ComboBoxItem Content="Offline CTranslate2 (GPU)"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="DeepL API Key" FontSize="12" Foreground="#666666"/>
                                        <TextBox x:Name="DeepLApiKeyBox" Width="400" HorizontalAlignment="Left" PasswordChar="•" Watermark="..."/>
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                            
                            <!-- AI Dịch -->
                            <TabItem Header="{DynamicResource Pref_Trans_CloudAI}">
                                <StackPanel Spacing="16" Margin="0,16,0,0">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource Pref_AI_Model}" FontSize="12" Foreground="#666666"/>
                                        <ComboBox x:Name="AiModelCombo" Width="240" SelectedIndex="0">
                                            <ComboBoxItem Content="Gemini 1.5 Pro"/>
                                            <ComboBoxItem Content="Gemini 1.5 Flash"/>
                                            <ComboBoxItem Content="Claude 3 Haiku"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource Pref_AI_ApiKey}" FontSize="12" Foreground="#666666"/>
                                        <TextBox x:Name="ApiKeyBox" Width="400" HorizontalAlignment="Left" PasswordChar="•" Watermark="sk-proj-..."/>
                                        <Button Content="{DynamicResource Pref_AI_TestConnection}" Width="150" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource Pref_AI_SystemPrompt}" FontSize="12" Foreground="#666666"/>
                                        <TextBox x:Name="SystemPromptBox" Height="100" AcceptsReturn="True" TextWrapping="Wrap" Watermark="You are a helpful translator..."/>
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>

                            <!-- Local AI -->
                            <TabItem Header="{DynamicResource Pref_Trans_LocalAI}">
                                <StackPanel Spacing="16" Margin="0,16,0,0">
                                    
                                    <!-- Setup / Installation Assistant (Đưa lên đầu) -->
                                    <StackPanel Spacing="8">
                                        <!-- Tiêu đề và nút Add (+) -->
                                        <Grid ColumnDefinitions="*, Auto" Width="400" HorizontalAlignment="Left">
                                            <TextBlock Grid.Column="0" Text="Quản lý Mô hình Dịch thuật" FontSize="12" FontWeight="Bold" Foreground="#111111" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" x:Name="ShowInstallBtn" Content="+" Width="24" Height="24" FontSize="14" FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="ShowInstallBtn_Click" ToolTip.Tip="Cài đặt mô hình mới" Padding="0"/>
                                        </Grid>
                                        
                                        <!-- Giao diện CHƯA CÀI ĐẶT (hoặc khi click +) -->
                                        <StackPanel x:Name="UninstalledPanel" Spacing="6" Margin="0,4,0,0" IsVisible="True">
                                            <TextBlock Text="Lựa chọn Mô hình dịch thuật để tải về:" FontSize="11" Foreground="#666666"/>
                                            <Grid ColumnDefinitions="*, Auto" Width="400" HorizontalAlignment="Left">
                                                <ComboBox Grid.Column="0" x:Name="InstallModelCombo" Width="280" SelectedIndex="0" Margin="0,0,8,0">
                                                    <ComboBoxItem Content="NLLB-200 600M (600MB - Khuyến nghị)"/>
                                                    <ComboBoxItem Content="OPUS-MT En-Vi (150MB - Siêu nhẹ)"/>
                                                </ComboBox>
                                                <Button Grid.Column="1" x:Name="StartInstallBtn" Content="Tải &amp; Cài đặt" Click="StartInstallBtn_Click" Classes="PrimaryBtn" Width="112" HorizontalContentAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                        
                                        <!-- Giao diện ĐÃ CÀI ĐẶT -->
                                        <StackPanel x:Name="InstalledPanel" Spacing="6" Margin="0,4,0,0" IsVisible="False">
                                            <!-- Dòng NLLB-200 -->
                                            <Grid x:Name="NllbRow" ColumnDefinitions="Auto, *, Auto, Auto" Width="420" HorizontalAlignment="Left" Margin="0,2" VerticalAlignment="Center">
                                                <RadioButton Grid.Column="0" x:Name="UseNllbRadio" GroupName="ModelGroup" IsChecked="True" Checked="UseNllbRadio_Checked" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="NLLB-200 600M (INT8)" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" Margin="8,0"/>
                                                <Button Grid.Column="2" Content="Kiểm tra cập nhật" Click="UpdateNllbBtn_Click" FontSize="11" Margin="0,0,8,0" Padding="8,4"/>
                                                <Button Grid.Column="3" Content="Xóa" Click="DeleteNllbBtn_Click" FontSize="11" Foreground="Red" Padding="8,4"/>
                                            </Grid>
                                            
                                            <!-- Dòng OPUS-MT -->
                                            <Grid x:Name="OpusRow" ColumnDefinitions="Auto, *, Auto, Auto" Width="420" HorizontalAlignment="Left" Margin="0,2" VerticalAlignment="Center">
                                                <RadioButton Grid.Column="0" x:Name="UseOpusRadio" GroupName="ModelGroup" Checked="UseOpusRadio_Checked" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="OPUS-MT English-Vietnamese" FontSize="12" FontWeight="Medium" VerticalAlignment="Center" Margin="8,0"/>
                                                <Button Grid.Column="2" Content="Kiểm tra cập nhật" Click="UpdateOpusBtn_Click" FontSize="11" Margin="0,0,8,0" Padding="8,4"/>
                                                <Button Grid.Column="3" Content="Xóa" Click="DeleteOpusBtn_Click" FontSize="11" Foreground="Red" Padding="8,4"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Divider -->
                                    <Border BorderBrush="#E5E5E5" BorderThickness="0,1,0,0" Width="400" HorizontalAlignment="Left" Margin="0,4"/>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{DynamicResource Pref_LocalAI_ServiceUrl}" FontSize="12" Foreground="#666666"/>
                                        <TextBox x:Name="OfflineTranslateUrlBox" Width="400" HorizontalAlignment="Left" Watermark="http://127.0.0.1:11435"/>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Plugin Server Directory (Thư mục Server dịch offline)" FontSize="12" Foreground="#666666"/>
                                        <TextBox x:Name="OfflineServerDirBox" Width="400" HorizontalAlignment="Left" Watermark="plugins/atom26"/>
                                    </StackPanel>
                                    
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Trạng thái Plugin Server:" FontSize="12" Foreground="#666666"/>
                                        <TextBlock x:Name="OfflineServerStateText" Text="Đang dừng" FontSize="12" FontWeight="Bold" Foreground="#666666"/>
                                        
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <Button x:Name="StartOfflineServerBtn" Content="Khởi động Server" Width="130" HorizontalContentAlignment="Center" Click="StartOfflineServerBtn_Click"/>
                                            <Button x:Name="StopOfflineServerBtn" Content="Dừng Server" Width="130" HorizontalContentAlignment="Center" Click="StopOfflineServerBtn_Click"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="8" Margin="0,8,0,0">
                                        <Button x:Name="TestOfflineConnectionBtn" Content="{DynamicResource Pref_AI_TestConnection}" Width="150" HorizontalContentAlignment="Center" Click="TestOfflineConnectionBtn_Click"/>
                                        <TextBlock x:Name="OfflineStatusText" Text="" FontSize="12" Foreground="#666666" TextWrapping="Wrap" Width="400" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                    
                    <!-- Appearance Tab -->
                    <StackPanel x:Name="TabAppearance" IsVisible="False" Spacing="24">
                        <TextBlock Text="{DynamicResource Tab_Appearance}" FontSize="24" FontWeight="SemiBold" Foreground="#111111"/>
                        <!-- Mock content for Appearance -->
                        <TextBlock Text="Cấu hình giao diện sẽ được bổ sung sau." Foreground="#666666"/>
                    </StackPanel>

                    <!-- Network Tab -->
                    <StackPanel x:Name="TabNetwork" IsVisible="False" Spacing="24">
                        <TextBlock Text="{DynamicResource Tab_Network}" FontSize="24" FontWeight="SemiBold" Foreground="#111111"/>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{DynamicResource Pref_Advanced_Network}" FontSize="12" Foreground="#666666"/>
                                <TextBox x:Name="NetworkProxyBox" Width="400" HorizontalAlignment="Left" Watermark="http://127.0.0.1:8080"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Advanced Tab -->
                    <StackPanel x:Name="TabAdvanced" IsVisible="False" Spacing="24">
                        <TextBlock Text="{DynamicResource Tab_Advanced}" FontSize="24" FontWeight="SemiBold" Foreground="#111111"/>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{DynamicResource Pref_Advanced_PipeName}" FontSize="12" Foreground="#666666"/>
                                <TextBox x:Name="PipeNameBox" Width="240" HorizontalAlignment="Left" Text="MSLCCaptionPipe"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="{DynamicResource Pref_Advanced_LogDir}" FontSize="12" Foreground="#666666"/>
                                <Grid ColumnDefinitions="*, Auto" Width="400" HorizontalAlignment="Left">
                                    <TextBox Grid.Column="0" Text="./logs/" IsReadOnly="True" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="{DynamicResource Pref_Advanced_OpenDir}"/>
                                </Grid>
                            </StackPanel>
                            <CheckBox x:Name="VerboseLogCheck" Content="Ghi log chi tiết (Verbose Logging)" IsChecked="False" Margin="0,8,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Hotkeys Tab -->
                    <StackPanel x:Name="TabHotkeys" IsVisible="False" Spacing="24">
                        <TextBlock Text="{DynamicResource Tab_Hotkeys}" FontSize="24" FontWeight="SemiBold" Foreground="#111111"/>
                        <StackPanel Spacing="16">
                            <CheckBox x:Name="EnableHotkeysCheck" Content="{DynamicResource Pref_Hotkeys_Enable}" IsChecked="True"/>
                            
                            <TextBlock Text="{DynamicResource Pref_Hotkeys_ListTitle}" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" Foreground="#333333"/>
                            
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="220,*" Margin="0,4,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Pref_Hotkeys_ToggleOverlay}" FontWeight="Medium" Padding="0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Alt + Shift + O" Foreground="#FF8400" Padding="0,6"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Pref_Hotkeys_ToggleTranslate}" FontWeight="Medium" Padding="0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Alt + Shift + T" Foreground="#FF8400" Padding="0,6"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Pref_Hotkeys_CycleLanguage}" FontWeight="Medium" Padding="0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Alt + Shift + L" Foreground="#FF8400" Padding="0,6"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Pref_Hotkeys_ClearText}" FontWeight="Medium" Padding="0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Alt + Shift + C" Foreground="#FF8400" Padding="0,6"/>
                                
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Pref_Hotkeys_FontSizeUp}" FontWeight="Medium" Padding="0,6"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="Alt + Shift + Up" Foreground="#FF8400" Padding="0,6"/>
                                
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="{DynamicResource Pref_Hotkeys_FontSizeDown}" FontWeight="Medium" Padding="0,6"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="Alt + Shift + Down" Foreground="#FF8400" Padding="0,6"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                    
                    </Panel>
                </ScrollViewer>
                
                <!-- Action Buttons -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" Margin="0,24,0,0">
                    <Button Grid.Column="0" Content="{DynamicResource Pref_Action_Reset}" Click="ResetBtn_Click" Classes="SecondaryBtn" Background="#F3F3F3" Padding="16,8"/>
                    <Button Grid.Column="2" Content="{DynamicResource Pref_Action_Close}" Click="CloseBtn_Click" Background="#111111" Foreground="#FFFFFF" Padding="24,8"/>
                </Grid>
                
            </Grid>
        </Border>
        
    </Grid>
</Window>

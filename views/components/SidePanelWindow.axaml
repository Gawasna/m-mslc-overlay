<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="m_mslc_overlay.views.components.SidePanelWindow"
        Title="MSLC Side Panel - Live Controller"
        Background="{StaticResource BgWindowBrush}"
        MinWidth="400" MinHeight="600"
        Width="480" Height="800"
        SystemDecorations="None"
        WindowStartupLocation="Manual"
        PointerPressed="Window_PointerPressed"
        PointerMoved="Window_PointerMoved">

    <Grid RowDefinitions="Auto, Auto, *, Auto">
        <!-- 1. Custom Title Bar (32px) -->
        <Border Grid.Row="0" 
                Height="32" 
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="0,0,0,1"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="*, Auto">
                <!-- Title Text -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="MSLC Side Panel - Live Controller &amp; Transcript" 
                               FontSize="11" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- System Action Buttons (Minimize/Close Custom styling) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">
                    <!-- Minimize Button -->
                    <Button Click="MinimizeButton_Click"
                            Width="46" Height="31" 
                            Classes="TitleBarBtn"
                            ToolTip.Tip="Minimize">
                        <Rectangle Width="10" Height="1" Fill="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <!-- Close Button -->
                    <Button Click="CloseButton_Click"
                            Width="46" Height="31" 
                            Classes="TitleBarBtn CloseBtn"
                            ToolTip.Tip="Close">
                        <PathIcon Data="{StaticResource IconClosePanel}" Width="10" Height="10" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Flat Tab Control (36px) -->
        <Border Grid.Row="1" 
                Height="36" 
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, *">
                <!-- Tab 1: Transcript & History -->
                <Border x:Name="TabTranscriptIndicator" Grid.Column="0" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,2">
                    <Button x:Name="TabTranscriptBtn" Click="TabTranscript_Click"
                            Background="Transparent" BorderThickness="0" CornerRadius="0"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <TextBlock x:Name="TabTranscriptText" Text="Transcript &amp; History" 
                                   FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Button>
                </Border>

                <!-- Tab 2: Live Subtitle Generator -->
                <Border x:Name="TabGeneratorIndicator" Grid.Column="1" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                    <Button x:Name="TabGeneratorBtn" Click="TabGenerator_Click"
                            Background="Transparent" BorderThickness="0" CornerRadius="0"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <TextBlock x:Name="TabGeneratorText" Text="Live Subtitle Generator" 
                                   FontSize="11" FontWeight="Normal" 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- 3. Dynamic Content Area (Fill) -->
        <Grid Grid.Row="2">
            <!-- PANEL 1: TRANSCRIPT VIEW -->
            <Grid x:Name="TranscriptPanel" RowDefinitions="Auto, *" IsVisible="True">
                <!-- Transcript Toolbar (40px) -->
                <Border Grid.Row="0" Height="40" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="0,0,0,1" Padding="12,0">
                    <DockPanel LastChildFill="False">
                        <!-- Left: Search Box, Font Selector, Line Spacing Selector -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBox x:Name="SearchBox" 
                                     Watermark="Search transcript..." 
                                     FontSize="10" 
                                     Width="120" Height="26"
                                     VerticalContentAlignment="Center"
                                     Background="{StaticResource BgWindowBrush}" 
                                     BorderBrush="{StaticResource BorderLightBrush}" 
                                     BorderThickness="1" 
                                     CornerRadius="4"
                                     VerticalAlignment="Center">
                                <TextBox.InnerLeftContent>
                                    <PathIcon Data="{StaticResource IconSearch}" Width="11" Height="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </TextBox.InnerLeftContent>
                            </TextBox>
                            
                            <!-- Font Family Selector (Georgia, Lora, JetBrains Mono, Inter, Segoe UI) -->
                            <ComboBox x:Name="FontFamilySelector" 
                                      Width="110" Height="26" FontSize="10" 
                                      SelectedIndex="0" 
                                      VerticalAlignment="Center" 
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="FontFamilySelector_SelectionChanged">
                                <ComboBoxItem Content="Georgia"/>
                                <ComboBoxItem Content="Lora"/>
                                <ComboBoxItem Content="JetBrains Mono"/>
                                <ComboBoxItem Content="Inter"/>
                                <ComboBoxItem Content="Segoe UI"/>
                            </ComboBox>
                            
                            <!-- Line Spacing Selector (1.15x, 1.5x, 2.0x) -->
                            <ComboBox x:Name="LineSpacingSelector" 
                                      Width="60" Height="26" FontSize="10" 
                                      SelectedIndex="0" 
                                      VerticalAlignment="Center" 
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="LineSpacingSelector_SelectionChanged">
                                <ComboBoxItem Content="1.15x"/>
                                <ComboBoxItem Content="1.5x"/>
                                <ComboBoxItem Content="2.0x"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Right: Action Buttons -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <!-- Export -->
                            <Button Click="ExportBtn_Click" Width="26" Height="26" Padding="0" Classes="SecondaryBtn" ToolTip.Tip="Export to File">
                                <PathIcon Data="{StaticResource IconDownload}" Width="12" Height="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <!-- Copy All -->
                            <Button Click="CopyAllBtn_Click" Width="26" Height="26" Padding="0" Classes="SecondaryBtn" ToolTip.Tip="Copy All">
                                <PathIcon Data="{StaticResource IconCopy}" Width="12" Height="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <!-- Auto Scroll (Toggle) -->
                            <ToggleButton x:Name="AutoScrollToggle" IsChecked="True" Width="26" Height="26" Padding="0" ToolTip.Tip="Toggle Auto Scroll">
                                <PathIcon Data="{StaticResource IconArrowDownToLine}" Width="12" Height="12"/>
                            </ToggleButton>
                            <!-- Clear History -->
                            <Button Click="ClearHistoryBtn_Click" Width="26" Height="26" Padding="0" Classes="SecondaryBtn" ToolTip.Tip="Clear History">
                                <PathIcon Data="{StaticResource IconTrash}" Width="12" Height="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Transcript List Area (Paper Style) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource BgWindowBrush}" Padding="16,16">
                    <!-- Paper Sheet Container -->
                    <Border Background="#FFFFFF" 
                            BorderBrush="{StaticResource BorderLightBrush}" 
                            BorderThickness="1" 
                            CornerRadius="2"
                            Margin="0,0,0,16"
                            Padding="24"
                            BoxShadow="0 4 12 0 #15000000">
                        <StackPanel Spacing="16">
                            <!-- Paper Header -->
                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="LIVE STREAM TRANSCRIPT" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               FontFamily="Georgia"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Session: Live Translation" 
                                               FontSize="9" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                
                                <!-- Language Selector EN | VI -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                    <ToggleButton x:Name="BtnLangEn" Content="EN" 
                                                  Click="BtnLangEn_Click"
                                                  IsChecked="False"
                                                  Width="34" Height="24" FontSize="10" Padding="0"
                                                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  CornerRadius="4,0,0,4" BorderThickness="1,1,0,1" BorderBrush="{StaticResource BorderLightBrush}"/>
                                    <ToggleButton x:Name="BtnLangVi" Content="VI" 
                                                  Click="BtnLangVi_Click"
                                                  IsChecked="True"
                                                  Width="34" Height="24" FontSize="10" Padding="0"
                                                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  CornerRadius="0,4,4,0" BorderThickness="1" BorderBrush="{StaticResource BorderLightBrush}"/>
                                </StackPanel>
                            </Grid>
                            
                            <Separator Height="1" Background="{StaticResource BorderLightBrush}" Margin="0,0,0,8"/>
                            
                            <!-- Transcript Paper Content (Paragraphs) -->
                            <StackPanel x:Name="TextEnContainer" Spacing="12" IsVisible="False">
                                <TextBlock FontFamily="Georgia" FontSize="12" LineHeight="19" TextWrapping="Wrap" Foreground="#222222"
                                           Text="Hello everyone, welcome to the MSLC live stream today. In this stream, we are going to showcase the new overlay feature. This allows real-time translation with very low latency. You can customize the font sizes, backgrounds, and positions."/>
                                <TextBlock FontFamily="Georgia" FontSize="12" LineHeight="19" TextWrapping="Wrap" Foreground="#222222"
                                           Text="We have been working hard on this release to bring you the best possible experience. The system now integrates smoothly with multi-agent translation pipelines, providing contextual adjustments and reducing translation errors by up to forty percent."/>
                                <TextBlock FontFamily="Georgia" FontSize="12" LineHeight="19" TextWrapping="Wrap" Foreground="#222222"
                                           Text="Please feel free to ask any questions in the chat, and our moderators will help answer them. We will start the demo in just a few minutes, so stay tuned!"/>
                            </StackPanel>

                            <StackPanel x:Name="TextViContainer" Spacing="12" IsVisible="True">
                                <TextBlock FontFamily="Georgia" FontSize="12" LineHeight="19" TextWrapping="Wrap" Foreground="#222222"
                                           Text="Xin chào mọi người, chào mừng đến với buổi phát trực tiếp MSLC hôm nay. Trong buổi phát sóng này, chúng tôi sẽ giới thiệu tính năng overlay mới. Tính năng này cho phép dịch thuật theo thời gian thực với độ trễ rất thấp. Bạn có thể tùy chỉnh kích thước phông chữ, hình nền và vị trí."/>
                                <TextBlock FontFamily="Georgia" FontSize="12" LineHeight="19" TextWrapping="Wrap" Foreground="#222222"
                                           Text="Chúng tôi đã làm việc chăm chỉ cho bản phát hành này để mang lại cho bạn trải nghiệm tốt nhất có thể. Hệ thống hiện tích hợp mượt mà với các đường ống dịch thuật đa tác nhân, cung cấp các điều chỉnh theo ngữ cảnh và giảm tới bốn mươi phần trăm lỗi dịch thuật."/>
                                <TextBlock FontFamily="Georgia" FontSize="12" LineHeight="19" TextWrapping="Wrap" Foreground="#222222"
                                           Text="Vui lòng đặt bất kỳ câu hỏi nào trong phần chat, điều phối viên của chúng tôi sẽ giúp trả lời. Chúng tôi sẽ bắt đầu bản demo chỉ sau vài phút nữa, hãy chú ý theo dõi!"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>

            <!-- PANEL 2: LIVE GENERATOR VIEW -->
            <ScrollViewer x:Name="GeneratorPanel" VerticalScrollBarVisibility="Auto" Background="{StaticResource BgWindowBrush}" IsVisible="False">
                <Border Padding="12">
                    <StackPanel Spacing="12">
                        
                        <!-- 1. Manual Subtitle Card -->
                        <Border Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Manual Subtitle Generator (Nhập phụ đề thủ công)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                
                                <!-- Multiline TextBox -->
                                <TextBox x:Name="ManualSubtitleInput" 
                                         Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                         Watermark="Nhập phụ đề hoặc thông báo muốn phát lên màn hình tại đây... (Nhấn Enter hoặc click Send)"
                                         FontSize="10"/>
                                
                                <!-- Control Row -->
                                <DockPanel LastChildFill="False">
                                    <CheckBox DockPanel.Dock="Left" x:Name="AutoClearCheck" IsChecked="True" VerticalAlignment="Center">
                                        <TextBlock Text="Auto-clear after send" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </CheckBox>
                                    <Button Click="SendManualBtn_Click" DockPanel.Dock="Right" Classes="PrimaryBtn" Height="26" Padding="16,0" VerticalAlignment="Center">
                                        <TextBlock Text="Send to Overlay" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                    </Button>
                                </DockPanel>

                                <!-- Quick Buttons (Sized smaller and aligned properly) -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                    <TextBlock Text="Quick:" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                    <Button Click="QuickAnnounceBtn_Click" Content="[Alo 1 2 3]" FontSize="9" Padding="8,0" Classes="SecondaryBtn" Height="22" MinHeight="0" MinWidth="0" VerticalContentAlignment="Center"/>
                                    <Button Click="QuickAnnounceBtn_Click" Content="[Tạm nghỉ 5p]" FontSize="9" Padding="8,0" Classes="SecondaryBtn" Height="22" MinHeight="0" MinWidth="0" VerticalContentAlignment="Center"/>
                                    <Button Click="QuickAnnounceBtn_Click" Content="[Lỗi kỹ thuật]" FontSize="9" Padding="8,0" Classes="SecondaryBtn" Height="22" MinHeight="0" MinWidth="0" VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 2. Teleprompter / Script Prompter Card -->
                        <Border Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Teleprompter / Script Prompter (Kịch bản sẵn)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                
                                <!-- Load Script Row -->
                                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                    <TextBox Grid.Column="0" x:Name="ScriptPathInput" Text="D:/scripts/presentation_v2.srt" Height="24" MinHeight="0" Padding="6,2" FontSize="9" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Click="LoadScriptBtn_Click" Classes="SecondaryBtn" Height="24" MinHeight="0" Padding="10,0" VerticalAlignment="Center" VerticalContentAlignment="Center">
                                        <TextBlock Text="Load Script" FontSize="9"/>
                                    </Button>
                                </Grid>

                                <!-- Script Preview Block -->
                                <Border Background="{StaticResource BgWindowBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                                    <StackPanel Spacing="6">
                                        <!-- Previous Line -->
                                        <TextBlock Text="[00:03] Thank you for joining our keynote." FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        
                                        <!-- Active Line Highlight -->
                                        <Border Background="#1AFF8400" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" CornerRadius="2" Padding="4,2">
                                            <TextBlock Text="[00:08] Today we will announce our new translation engine." FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap"/>
                                        </Border>
                                        
                                        <!-- Next Line -->
                                        <TextBlock Text="[00:15] It provides real-time multi-agent sync." FontSize="9" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Prompter Control Row -->
                                <Grid ColumnDefinitions="*, *, *">
                                    <!-- Prev -->
                                    <Button Click="PrompterPrev_Click" Grid.Column="0" Classes="SecondaryBtn" Height="28" MinHeight="0" Margin="0,0,4,0" VerticalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <PathIcon Data="{StaticResource IconArrowLeft}" Width="10" Height="10" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Prev" FontSize="9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Next -->
                                    <Button Click="PrompterNext_Click" Grid.Column="1" Classes="PrimaryBtn" Height="28" MinHeight="0" Margin="2,0" VerticalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <PathIcon Data="{StaticResource IconPlay}" Width="10" Height="10" Foreground="White"/>
                                            <TextBlock Text="Next (Space)" FontSize="10" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <!-- Reset -->
                                    <Button Click="PrompterReset_Click" Grid.Column="2" Classes="SecondaryBtn" Height="28" MinHeight="0" Margin="4,0,0,0" VerticalContentAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <PathIcon Data="{StaticResource IconReplay}" Width="10" Height="10" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Reset" FontSize="9" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 3. Sync & Delay Card -->
                        <Border Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, *, Auto">
                                <TextBlock Grid.Column="0" Text="Sync Delay:" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                
                                <Button Click="SyncMinus_Click" Grid.Column="1" Classes="SecondaryBtn" Width="50" Height="22" MinHeight="0" VerticalAlignment="Center" Margin="0,0,8,0" VerticalContentAlignment="Center">
                                    <TextBlock Text="-100ms" FontSize="9"/>
                                </Button>
                                
                                <TextBlock Grid.Column="2" x:Name="SyncDelayText" Text="+300 ms" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                
                                <Button Click="SyncPlus_Click" Grid.Column="3" Classes="SecondaryBtn" Width="50" Height="22" MinHeight="0" VerticalAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="+100ms" FontSize="9"/>
                                </Button>
                                
                                <Border Grid.Column="4" Height="1" Background="Transparent"/>
                                
                                <!-- Toggle Pipeline Sync -->
                                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <ToggleSwitch x:Name="PipelineSyncSwitch" IsChecked="True" 
                                                  OnContent="" OffContent="" 
                                                  MinWidth="0" Margin="0"/>
                                    <TextBlock Text="Pipeline Sync" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- 4. Downbar (Status Bar) (24px) -->
        <Border Grid.Row="3" 
                Height="24" 
                Background="{StaticResource BgWindowBrush}" 
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid ColumnDefinitions="*, Auto">
                <!-- Left Info -->
                <TextBlock Grid.Column="0" x:Name="StatusBarLeftText" 
                           Text="Total: 142 lines | Saved" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="9" 
                           VerticalAlignment="Center"/>
                <!-- Right Info -->
                <TextBlock Grid.Column="1" x:Name="StatusBarRightText" 
                           Text="Auto-save: ON" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="9" 
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>

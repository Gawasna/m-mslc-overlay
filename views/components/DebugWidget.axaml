<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="m_mslc_overlay.views.components.DebugWidget"
        Title="DebugWidget">
    <StackPanel>
        <Button x:Name="InterruptBtn" Click="InterruptBtn_Click" Content="Interrupt Render"/>
        <TextBox x:Name="JsonInput"/>
        <Button Content="Send JSON" Click="SendJsonBtn_Click"/>
        <Button Content="Send Final" Click="SendFinalBtn_Click"/>
        <Button Content="Reset State" Click="ResetStateBtn_Click"/>
        <ScrollViewer x:Name="LogScroll" Height="150">
            <SelectableTextBlock x:Name="LogText"/>
        </ScrollViewer>
        <Button Content="Clear Logs" Click="ClearLogsBtn_Click"/>
        <Button Content="Close" Click="CloseBtn_Click"/>
    </StackPanel>
</Window>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="m_mslc_overlay.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://m-mslc-overlay/assets/themes/Colors.axaml"/>
                <ResourceInclude Source="avares://m-mslc-overlay/assets/themes/Metrics.axaml"/>
                <ResourceInclude Source="avares://m-mslc-overlay/assets/themes/TranscriptConverters.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <materialIcons:MaterialIconStyles />
        <StyleInclude Source="avares://m-mslc-overlay/assets/styles/Controls.axaml"/>
    </Application.Styles>
</Application>